# =============================================================================
# DYSON — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# -----------------------------------------------------------------------------
# Database — Supabase (Postgres + pgvector)
# Get these from: https://supabase.com/dashboard → project → settings → database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# JWT — Auth
# Generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
CONNECTOR_TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Slack
# Get from: https://api.slack.com/apps → your app → credentials
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub
# Get from: https://github.com/settings/apps → your app
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Google Cloud Platform
# Get project ID from: https://console.cloud.google.com
# GOOGLE_APPLICATION_CREDENTIALS: path to your service account JSON key (dev only)
# In production on Cloud Run, use Workload Identity — no key file needed
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# -----------------------------------------------------------------------------
# Google Cloud Storage — raw event log archive
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=dyson-raw-events

# -----------------------------------------------------------------------------
# Google Cloud Tasks — ingestion job queue
# -----------------------------------------------------------------------------
CLOUD_TASKS_QUEUE_NAME=dyson-ingestion
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_HANDLER_URL=https://[YOUR-CLOUD-RUN-URL]/jobs

# -----------------------------------------------------------------------------
# Google Cloud Pub/Sub — event streaming between modules
# -----------------------------------------------------------------------------
PUBSUB_TOPIC_INGESTION=dyson-ingestion-events
PUBSUB_TOPIC_PROCESSING=dyson-processing-events
PUBSUB_SUBSCRIPTION_PROCESSING=dyson-processing-sub
PUBSUB_SUBSCRIPTION_GRAPH=dyson-graph-sub

# -----------------------------------------------------------------------------
# AI — Cohere (embeddings)
# Get from: https://dashboard.cohere.com/api-keys
# -----------------------------------------------------------------------------
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# AI — Google Gemini Flash (WHY Engine LLM)
# Get from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# -----------------------------------------------------------------------------
# Python Agent Runtime
# URL of the Python FastAPI microservice (backend/python/).
# Dev: start with `cd backend/python && uvicorn agent_runtime.main:app --port 8001`
# Prod: Cloud Run service URL of the Python container
# Optional — agent features degrade gracefully if not set
# -----------------------------------------------------------------------------
AGENT_RUNTIME_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Redis — distributed rate limiting (required in production)
# Recommended: Upstash Redis (serverless, no VPC connector needed on Cloud Run)
# Get from: https://console.upstash.com → create database → .env tab
# Leave empty in local dev — falls back to in-memory (single-instance only)
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6380

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_PER_MINUTE=100
WHY_ENGINE_RATE_LIMIT_MAX_PER_MINUTE=10

# -----------------------------------------------------------------------------
# CORS — allowed origins (comma-separated)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://app.dyson.ai

# -----------------------------------------------------------------------------
# Job secret — protects /jobs endpoints called by Cloud Tasks
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
JOB_SECRET=

# -----------------------------------------------------------------------------
# Email — Resend
# Free tier: 3000 emails/month. Get key from: https://resend.com/api-keys
# Required for: invitation emails, password reset
# If not set in dev, email content is logged to console instead.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=Dyson <noreply@yourdomain.com>
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability — Sentry (optional)
# Get DSN from: https://sentry.io → your project → settings → client keys
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Swagger UI
# Set to false in production
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=true
