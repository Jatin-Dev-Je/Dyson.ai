# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Dyson API ────────────────────────────────────────────────────────────────
# The TypeScript backend — agent runtime calls it to read/write memory
DYSON_API_URL=http://localhost:8080
DYSON_API_KEY=dys_your_api_key_here

# ── LLM ─────────────────────────────────────────────────────────────────────
# Gemini (recommended) — get from aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
# Local model — free, no API key needed, runs on CPU
# Options: all-MiniLM-L6-v2 (fast, 384-dim), all-mpnet-base-v2 (better, 768-dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cohere (optional — 1024-dim, better quality but costs money)
COHERE_API_KEY=

# ── NLP ──────────────────────────────────────────────────────────────────────
# spaCy model — run: python -m spacy download en_core_web_sm
SPACY_MODEL=en_core_web_sm

# ── Agent config ─────────────────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=120
CONFIDENCE_THRESHOLD=0.72
